    "from langchain_core.runnables import RunnableLambda\n",
    "\n",
    "normalizar = RunnableLambda(lambda x: {'tema': x.strip().lower()})\n",
    "chain_lcel = normalizar | prompt | llm | parser\n",
    "\n",
    "print(chain_lcel.invoke('  AGENTES EN IA  '))"
